  },
  "devDependencies": {
    "@types/react": "^19",
    "@types/react-dom": "^19.1.7",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5",
    "next": ">=14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7",
    "sonner": "^2"
  }
