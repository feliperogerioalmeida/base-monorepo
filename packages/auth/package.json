{
  "name": "@workspace/auth",
  "version": "0.0.1",
  "type": "module",
  "main": "./src/index.ts",
  "types": "./src/index.ts",
  "exports": {
    ".": {
      "types": "./src/index.ts",
      "default": "./src/index.ts"
    },
    "./client": {
      "types": "./src/client.ts",
      "default": "./src/client.ts"
    },
    "./schemas/*": "./src/schemas/*.ts",
    "./components/*": "./src/components/*.tsx",
    "./types": {
      "types": "./src/types.ts",
      "default": "./src/types.ts"
    }
  },
  "dependencies": {
    "@workspace/ui": "workspace:*",
    "better-auth": "^1.5.6",
    "lucide-react": "^0.577.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "typescript": "^5.9.3"
  },
  "peerDependencies": {
    "@hookform/resolvers": "^5",
    "next": ">=14",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-hook-form": "^7",
    "sonner": "^2"
  }
}
